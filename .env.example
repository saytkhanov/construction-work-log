# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=construction_log
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=3000
CORS_ORIGIN=*
# DATABASE_URL is composed from the POSTGRES_* values above inside docker-compose.
# For local (non-docker) development point it at your local Postgres, e.g.:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/construction_log?schema=public

# --- Frontend ---
FRONTEND_PORT=5173
