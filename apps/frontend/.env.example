# Необязательно для локального dev — по умолчанию фронт ходит на /api,
# который Vite проксирует на http://localhost:4000.

# Куда Vite проксирует /api в dev-режиме:
# VITE_API_PROXY_TARGET=http://localhost:4000

# Жёсткий базовый URL API (если не используете прокси):
# VITE_API_BASE_URL=http://localhost:4000/api
