# Базовый URL backend API.
# Если задан — фронт ходит на ${VITE_API_URL}/api напрямую.
# Если не задан — используется относительный /api (его проксирует Vite в dev
# и nginx в Docker).
VITE_API_URL=http://localhost:3000

# Куда Vite проксирует /api в dev-режиме (используется, только если VITE_API_URL не задан):
# VITE_API_PROXY_TARGET=http://localhost:3000
