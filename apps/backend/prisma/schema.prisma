generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Справочник видов работ (заполняется сидами)
model WorkType {
  id        String         @id @default(cuid())
  name      String         @unique
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  entries   WorkLogEntry[]

  @@map("work_types")
}

/// Запись журнала работ на объекте
model WorkLogEntry {
  id           String   @id @default(cuid())
  date         DateTime @db.Date // дата выполнения работ
  workTypeId   String   @map("work_type_id")
  workType     WorkType @relation(fields: [workTypeId], references: [id], onDelete: Restrict)
  volume       Decimal  @db.Decimal(12, 2) // выполненный объём
  unit         String // единица измерения: м³, м², шт, п.м.
  executorName String   @map("executor_name") // исполнитель / бригада
  comment      String?  @db.Text // примечание
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([workTypeId])
  @@map("work_log_entries")
}
